{
  "name": "hermes-wechat-acp",
  "version": "0.9.0",
  "description": "WeChat bridge for Hermes Agent with media support, interactive approval, and openclaw-weixin protocol alignment",
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "README_EN.md",
    "package.json"
  ],
  "bin": {
    "hermes-wechat-acp": "./dist/bin/wechat-acp.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node dist/bin/wechat-acp.js",
    "dev": "tsc --watch",
    "test": "node --import tsx/esm --test tests/**/*.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "applicationinsights": "^2.9.6",
    "qrcode-terminal": "^0.12.0",
    "silk-wasm": "^3.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YrracOwl/hermes-wechat-acp.git"
  },
  "homepage": "https://github.com/YrracOwl/hermes-wechat-acp#readme",
  "bugs": {
    "url": "https://github.com/YrracOwl/hermes-wechat-acp/issues"
  },
  "license": "MIT",
  "keywords": [
    "wechat",
    "acp",
    "agent-client-protocol",
    "hermes",
    "ai-agent",
    "bridge",
    "media",
    "approval"
  ]
}
